rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rank == "Admin";
    }

    // Helper to check if update is only to social fields
    function isSocialUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "followers", "following", "blocked", "friends", "friendRequestsIn", "friendRequestsSent"
      ]);
    }

    // Helper to check if post update is only to likes or views
    function isPostInteractionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likes", "views"]);
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        (request.auth.uid != userId && isSocialUpdate())
      );
      allow delete: if isAdmin();
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorUid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorUid ||
        isAdmin() ||
        isPostInteractionUpdate()
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.authorUid ||
        isAdmin()
      );
    }
  }
}
